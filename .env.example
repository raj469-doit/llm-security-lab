# LLM Security Lab — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Target LLM endpoint (OpenAI-compatible)
LLM_API_URL=https://api.openai.com/v1/chat/completions

# Your API key for the LLM under test
LLM_API_KEY=your-api-key-here

# Model identifier
LLM_MODEL=gpt-4o-mini

# Judge-LLM layer (optional — semantic detection of leaked information)
# Set to true to enable a second LLM as a referee for each test response
LLM_USE_JUDGE=false

# Use a different model for judging (optional — defaults to LLM_MODEL)
# Useful if you want a stronger model as the judge while testing a weaker one
# LLM_JUDGE_MODEL=gpt-4o
